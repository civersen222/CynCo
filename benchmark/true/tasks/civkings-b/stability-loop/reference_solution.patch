         # 2. Happiness & Stability
         self.happiness_system.update_city_count(len(self.cities))
+
+        # --- Stability-loop wiring: war and conquest drive stability down ---
+        at_war = bool(self.diplomacy_manager.get_active_wars(civ_name))
+        owned_cities = sum(1 for c in self.cities.values() if c.owner == civ_name)
+
+        # War: applying the war-declared penalty once when war begins, plus a
+        # smaller ongoing penalty for every turn the war drags on.
+        if at_war and not self._stability_war_active:
+            self.stability_system.apply_event_modifier("war_declared")
+            msgs.append("  Stability: war has destabilized the realm")
+        elif at_war:
+            self.stability_system.apply_change(-3)
+        self.stability_system.update_war_status(at_war)
+        self._stability_war_active = at_war
+
+        # Conquest: any net gain in owned cities reduces stability further.
+        if owned_cities > self._stability_owned_cities:
+            gained = owned_cities - self._stability_owned_cities
+            for _ in range(gained):
+                self.stability_system.apply_event_modifier("conquest")
+            self.stability_system.update_war_status(at_war, conquered_cities=gained)
+            msgs.append(f"  Stability: conquest of {gained} city(ies) breeds unrest")
+        self._stability_owned_cities = owned_cities
+
