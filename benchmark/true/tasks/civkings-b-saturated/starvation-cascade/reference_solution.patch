     def grow(self):
-        """Population growth each turn based on food surplus."""
+        """Population growth each turn based on food surplus.
+
+        When food income covers the population's consumption the city grows
+        as before. When it does not, the city *starves*: it accumulates
+        starvation turns, takes a happiness penalty, sheds population over
+        time (never below POPULATION_FLOOR), and — once the starvation is
+        severe / sustained — its stability is dragged down as well (see
+        calculate_yields).
+        """
         yields = self.calculate_yields()
         food = yields.get("food", 0)
         consumption = self.population * 1.5
+
         if food > consumption and self.population < 20:
+            # Healthy surplus: grow and shake off any prior starvation.
             self.population += 1
+            self.starvation_turns = 0
+            return
+
+        if food < consumption:
+            # Food deficit: the city starves.
+            self.starvation_turns += 1
+
+            # Happiness penalty grows with how long the famine has lasted,
+            # capped so a single famine cannot drive happiness arbitrarily
+            # negative.
+            self.happiness -= min(self.starvation_turns, 5)
+
+            # Lose population over turns, but never below the floor.
+            if self.population > self.POPULATION_FLOOR:
+                self.population -= 1
+        else:
+            # Exactly breaking even (or at the growth cap with a surplus):
+            # no growth, but no famine either.
+            self.starvation_turns = 0
 
