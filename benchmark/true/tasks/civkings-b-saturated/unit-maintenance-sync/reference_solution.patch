+    @classmethod
+    def maintenance_for_type(cls, unit_type: str) -> float:
+        """Authoritative per-turn maintenance for a unit type.
+
+        The canonical unit definitions in ``game_data.UNIT_TYPES`` are the
+        single source of truth. The local ``UNIT_MAINTENANCE`` table is only a
+        last-resort fallback for unit-type names that are not present in the
+        canonical definitions; a genuinely unknown type costs zero rather than
+        an arbitrary default fee.
+        """
+        utype = UNIT_TYPES.get(unit_type)
+        if utype is not None:
+            return float(utype.gold_maintenance)
+        return float(cls.UNIT_MAINTENANCE.get(unit_type, 0.0))
+
