+int32_t llama_context::activations_read(uint64_t since, llama_activation_view * out, int32_t n_max, uint64_t * cursor_out) {
+    std::lock_guard<std::mutex> lock(act_mutex);
+
+    act_read_buf.clear();
+    for (const auto & e : act_ring) {
+        if (e.cursor > since && (int32_t) act_read_buf.size() < n_max) {
+            act_read_buf.push_back(e);
+        }
+    }
+
+    for (size_t i = 0; i < act_read_buf.size(); ++i) {
+        const auto & e = act_read_buf[i];
+        out[i] = { e.cursor, e.layer, e.pos, e.token, e.values.data(), (int32_t) e.values.size() };
+    }
+
+    if (cursor_out) {
+        *cursor_out = act_cursor;
+    }
+
+    return (int32_t) act_read_buf.size();
+}
